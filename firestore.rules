rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return true
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rooms: Anyone authenticated can list/read/create. Only creator can update gameState.
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.createdAt is number;
      
      allow update: if isAuthenticated() && (
        // Creator/Admin can update anything (e.g. advance month, pause)
        resource.data.createdBy == request.auth.uid ||
        isAdmin() ||
        // Others can only update gameState as part of trades
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['gameState']))
      );

      allow delete: if isAuthenticated() && (
        !('createdBy' in resource.data) ||
        resource.data.createdBy == request.auth.uid || 
        isAdmin()
      );

      // Portfolios within a room
      match /portfolios/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && (
          request.auth.uid == userId ||
          (
            get(/databases/$(database)/documents/rooms/$(roomId)).data.createdBy == userId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cash']) &&
            request.resource.data.cash == resource.data.cash + 15
          )
        );
      }
    }
  }
}
